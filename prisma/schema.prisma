generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Single-row cache of the full DashboardState JSON — polled by the frontend.
model SystemState {
  id        Int      @id @default(autoincrement())
  state     Json
  updatedAt DateTime @updatedAt
}

model Setup {
  id              String   @id @default(cuid())
  fingerprintId   String?  @unique
  symbol          String
  timeframe       String
  direction       String   // LONG | SHORT
  rangeHigh       Float?
  rangeLow        Float?
  entryZoneLow    Float?
  entryZoneHigh   Float?
  sl              Float?
  tp1             Float?
  tp2             Float?
  tp3             Float?
  rr              Float?
  grade           String   @default("B")
  confidence      Int      @default(0)
  thesisType      String   @default("")
  note            String   @default("")
  lifecycleStatus String   @default("NEW")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trades          Trade[]
}

model Trade {
  id          String    @id @default(cuid())
  setupId     String?
  setup       Setup?    @relation(fields: [setupId], references: [id])
  symbol      String
  direction   String
  mode        String    @default("PAPER") // PAPER | LIVE
  entryPrice  Float?
  sl          Float?
  slCurrent   Float?
  slStatus    String    @default("INITIAL")
  tp1         Float?
  tp2         Float?
  tp3         Float?
  tp1Hit      Boolean   @default(false)
  tp2Hit      Boolean   @default(false)
  tp3Hit      Boolean   @default(false)
  slHit       Boolean   @default(false)
  status      String    @default("WAITING")
  riskPct     Float?
  sizeBtc     Float?
  openedAt    DateTime?
  closedAt    DateTime?
  closeReason String?
  resultR     Float?
  lesson      String    @default("")
  mistake     String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([symbol, status])
}

model RangeMemory {
  id                 String   @id
  symbol             String
  timeframe          String
  rangeHigh          Float
  rangeLow           Float
  midline            Float
  width              Float
  status             String   @default("NEW") // NEW|ACTIVE|TRADED|STALE|RESET
  tradeCount         Int      @default(0)
  lastTradeDirection String?
  lastTradeResult    String?
  freshLiquidity     Boolean  @default(true)
  reentryAllowed     Boolean  @default(true)
  createdAt          DateTime @default(now())
  lastTouchedAt      DateTime @default(now())

  @@unique([symbol, timeframe, rangeHigh, rangeLow])
  @@index([symbol, timeframe])
}

model SetupFingerprint {
  id            String    @id
  symbol        String
  timeframe     String
  direction     String
  rangeHigh     Float
  rangeLow      Float
  entryZoneHigh Float
  entryZoneLow  Float
  thesisType    String    @default("")
  status        String    @default("NEW")
  alreadyTraded Boolean   @default(false)
  tradedAt      DateTime?
  result        String?
  createdAt     DateTime  @default(now())

  @@index([symbol, timeframe, alreadyTraded])
}

model Cooldown {
  id            Int       @id @default(autoincrement())
  symbol        String
  timeframe     String
  direction     String?
  activatedAt   DateTime  @default(now())
  totalBars     Int       @default(5)
  remainingBars Int       @default(5)
  reason        String?
  active        Boolean   @default(true)

  @@index([symbol, timeframe, active])
}

model MarketSnapshot {
  id         Int      @id @default(autoincrement())
  symbol     String
  timeframe  String
  price      Float
  open       Float?
  high       Float?
  low        Float?
  regime     String?
  ema20      Float?
  ema50      Float?
  atr        Float?
  atr4H      Float?
  snapshotAt DateTime @default(now())

  @@index([symbol, snapshotAt])
}

model WebhookEvent {
  id          Int      @id @default(autoincrement())
  receivedAt  DateTime @default(now())
  symbol      String?
  signal      String?
  setupId     String?
  payload     Json
  processed   Boolean  @default(false)
  duplicate   Boolean  @default(false)
  blocked     Boolean  @default(false)
  blockReason String?
  error       String?

  @@index([setupId, receivedAt])
}

model Notification {
  id        Int      @id @default(autoincrement())
  sentAt    DateTime @default(now())
  channel   String   @default("telegram")
  message   String
  eventType String
  success   Boolean  @default(true)
  error     String?
}

// Immutable audit log — append-only, never updated or deleted
model AuditLog {
  id            Int      @id @default(autoincrement())
  ts            DateTime @default(now())
  action        String   // AuditAction enum value
  actor         String   // service name or 'webhook' | 'cron' | 'api'
  resource      String?  // e.g. tradeId, setupId
  correlationId String
  detail        Json     @default("{}")

  @@index([correlationId])
  @@index([action, ts])
}

// Health snapshot written by HealthService on each /api/v1/health/ready call
model SystemHealth {
  id            Int      @id @default(autoincrement())
  ts            DateTime @default(now())
  status        String   // ok | degraded | down
  dbOk          Boolean
  dbLatencyMs   Int
  activeProvider String
  providerHealth Json    @default("[]")

  @@index([ts])
}

// Lifecycle event log for a trade — one row per state transition
model TradeLifecycle {
  id            Int      @id @default(autoincrement())
  tradeId       String
  ts            DateTime @default(now())
  fromStatus    String
  toStatus      String
  event         String   // ENTRY_TRIGGERED | TP1_HIT | TP2_HIT | TP3_HIT | SL_HIT | MANUAL_CLOSE
  price         Float?
  correlationId String
  detail        Json     @default("{}")

  @@index([tradeId, ts])
}

// Single-row shadow verification metrics accumulator (id is always 1)
model KernelMetrics {
  id                   Int       @id
  totalWebhookEvents   Int       @default(0)
  totalKernelEvents    Int       @default(0)
  kernelTransitions    Int       @default(0)
  criticalDivergences  Int       @default(0)
  warningDivergences   Int       @default(0)
  infoDivergences      Int       @default(0)
  snapshotCount        Int       @default(0)
  totalLatencyMs       Float     @default(0)
  latencySamples       Int       @default(0)
  lastLatencyMs        Float     @default(0)
  lastSnapshotSeq      BigInt?
  firstEventAt         DateTime  @default(now())
  lastEventAt          DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// Classified divergence events between Kernel shadow and SystemState
model KernelDivergenceLog {
  id                Int      @id @default(autoincrement())
  ts                DateTime @default(now())
  severity          String   // INFO | WARNING | CRITICAL
  correlationId     String
  kernelMode        String
  systemMode        String
  kernelTradePhase  String?
  systemTradeStatus String?
  kernelTradeActive Boolean
  systemTradeActive Boolean
  detail            Json     @default("{}")

  @@index([severity, ts])
  @@index([correlationId])
}

// Immutable event log — the single source of truth for Core State Kernel.
// Never updated or deleted. seq is a global monotonic counter.
model KernelEvent {
  id            String   @id
  seq           BigInt   @unique
  previousSeq   BigInt
  ts            DateTime
  correlationId String
  sessionId     String
  source        String
  domain        String
  type          String
  version       Int      @default(1)
  tradeId       String?
  setupId       String?
  payload       Json     @default("{}")

  @@index([correlationId])
  @@index([domain, type])
  @@index([tradeId])
}

// Periodic full-state snapshots — enables fast recovery without replaying all events.
model KernelSnapshot {
  id         String   @id
  seq        BigInt   @unique
  createdAt  DateTime
  eventCount Int
  state      Json

  @@index([seq])
}
